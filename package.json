    "react-router-dom": "^7.9.6",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^2.15.4",
    "serverless-http": "^4.0.0",
    "sharp": "^0.34.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.3.5",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "vite": "^7.2.6",
    "z-ai-web-dev-sdk": "^0.0.10",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@netlify/functions": "^5.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "esbuild": "^0.24.2",
    "eslint": "^9",
    "prisma": "^6.11.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vite-plugin-prerender": "^1.0.8"
  }
}
