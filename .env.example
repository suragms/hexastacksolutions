# Copy to `.env` (or `.env.local`) and set values. Vite exposes only vars prefixed with VITE_.

# Backend API (Mongo + sync service)
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/hexastacksolutions
# API_PORT=4000
# CORS_ORIGIN=http://localhost:5173
# JWT_SECRET=change-me
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me

# Admin analytics dashboard (/admin). Change this before production.
VITE_ADMIN_PASSWORD=hexastack2025

# Optional: if set, the login form shows a username field and it must match this value.
# VITE_ADMIN_USER=admin

# HexaBill marketing site (product CTAs on /products/hexabill). Defaults to https://hexabillmarketingpage.com
# VITE_HEXABILL_MARKETING_URL=https://hexabillmarketingpage.com

# SEO: Google Search Console (verify https://www.hexastacksolutions.com) — paste the meta tag from GSC into index.html (see comment in <head>). Bing Webmaster: add site there separately.

# Google Business Profile — “Write a review” link (shows button on homepage testimonials). Get from Google Maps → your business → Ask for reviews.
# VITE_GOOGLE_REVIEW_URL=https://g.page/r/YourReviewLink

# Optional: frontend sync API URL (default already points to local API)
# VITE_API_BASE_URL=http://localhost:4000/api
