# =============================================================================
# HexaStack Solutions — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values. Never commit .env.
# Production (Vercel/Netlify): set in Project → Settings → Environment Variables, then redeploy.
# =============================================================================

# -----------------------------------------------------------------------------
# Required for API (Database, Auth, Admin)
# -----------------------------------------------------------------------------

# MongoDB connection string (Atlas: Connect → Drivers → Node.js).
# - Include database name: .../hexastacksolutions?...
# - Optional params if you see timeouts: &connectTimeoutMS=10000&serverSelectionTimeoutMS=10000
# - URL-encode special characters in the password. Allow IP (or 0.0.0/0) in Atlas Network Access.
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/hexastacksolutions?retryWrites=true&w=majority

# JWT secret for admin and client tokens. Use at least 32 characters in production.
# Production: must be set in Vercel/Netlify or admin login returns 503.
JWT_SECRET=hexastack-secure-secret-key-2024

# Admin panel password (/admin). Production: must be set or login returns 503.
# Local dev: defaults to hexastack@2024 if unset.
ADMIN_PASSWORD=hexastack@2024

# -----------------------------------------------------------------------------
# Optional — Email & notifications
# -----------------------------------------------------------------------------

# Where new contact form enquiries are sent (admin notification).
ADMIN_EMAIL=supporthexastack@hexastacksolutions.com

# Resend.com API key — enables sending reply emails from Admin Enquiries.
# Without it, replies are logged only.
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Optional — Server (local / Node)
# -----------------------------------------------------------------------------

# Port for local API server (default 3001).
PORT=3001

# development | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Optional — Frontend (Vite)
# -----------------------------------------------------------------------------

# API base URL for the frontend. Leave unset when API is same origin (e.g. Vercel: /api/*).
# Set only if the API is on a different domain (e.g. https://api.hexastacksolutions.com).
# VITE_API_URL=

# =============================================================================
# Summary
# =============================================================================
# Required (local + production): DATABASE_URL, JWT_SECRET, ADMIN_PASSWORD
# Optional: ADMIN_EMAIL, RESEND_API_KEY, PORT, NODE_ENV, VITE_API_URL
# Test DB: npm run db:test-connection (uses DATABASE_URL from .env)
# =============================================================================
