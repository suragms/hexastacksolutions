# Copy to .env and fill in values. Never commit .env.

# Database (required for server)
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Auth
JWT_SECRET=your-secret-min-32-chars-for-production

# Admin panel (/admin) — required in production; in development defaults to hexastack@2024 if missing
ADMIN_PASSWORD=hexastack@2024

# Optional: where contact form notifications are sent
ADMIN_EMAIL=supporthexastack@hexastacksolutions.com

# Optional: send enquiry reply emails (Resend.com)
RESEND_API_KEY=re_xxxx

# Server
PORT=3001
NODE_ENV=development
