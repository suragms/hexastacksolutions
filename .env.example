# Copy to .env and fill in values. Never commit .env.
# Production (Vercel/Netlify): set these in Project → Settings → Environment Variables.

# ============ Required for API ============
# MongoDB Atlas — use your connection string from Atlas → Connect → Drivers
# If you see "Server selection timeout" or "tlsv1 alert internal error" on Windows, add these params (after the existing ? or &):
#   &connectTimeoutMS=10000&serverSelectionTimeoutMS=10000
# Also: use Node 18+, allow your IP (or 0.0.0.0/0 for dev) in Atlas Network Access, and URL-encode any special chars in the password.
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&connectTimeoutMS=10000&serverSelectionTimeoutMS=10000

# JWT for client/auth tokens (min 32 chars in production)
JWT_SECRET=your-secret-min-32-chars-for-production

# Admin panel (/admin) — in dev defaults to hexastack@2024 if missing
ADMIN_PASSWORD=hexastack@2024

# ============ Optional ============
# Where contact form notifications are sent
ADMIN_EMAIL=supporthexastack@hexastacksolutions.com

# Send enquiry reply emails via Resend.com
RESEND_API_KEY=re_xxxx

# ============ Server ============
PORT=3001
NODE_ENV=development

# ============ Frontend (only if API is on a different domain) ============
# Leave unset when API and frontend are same origin (Vercel/Netlify).
# VITE_API_URL=https://your-api-domain.com
